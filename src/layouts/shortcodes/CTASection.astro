---
/**
 * CTASection Component
 *
 * Styled call-to-action block for the Fractional CTO transition.
 * Dark background for strong visual contrast signaling end of section.
 *
 * ✅ MDX usage:
 * <CTASection title="Ready to Transform Your Technology Strategy?" href="/contact" linkText="Schedule a Consultation">
 *   Discover how our Fractional CTO service can help...
 * </CTASection>
 */
import { markdownify } from "@/lib/utils/textConverter";
import { getLocaleUrlCTM, useTranslations } from "@/lib/utils/i18nUtils.ts";
import Button from "@/layouts/components/Button.astro";

interface Props {
  title?: string;
  href?: string;
  linkText?: string;
  class?: string;
}

const { title, href, linkText, class: className = "" } = Astro.props;

const t = await useTranslations(Astro.currentLocale as string);

const slug = href ? getLocaleUrlCTM(href, Astro.currentLocale) : null;
---

<section
  class:list={[
    "not-prose mb-10 rounded-xl bg-dark/95 p-8 text-center lg:p-14",
    className,
  ]}
>
  {title && (
    <h3
      class="text-h3-sm md:text-h2 font-secondary font-bold text-white m-0 mb-4"
      set:html={markdownify(title)}
    />
  )}
  <div class="prose-styles prose-p:text-white/80 prose-p:text-lg prose-p:last:mb-6">
    <slot />
  </div>
  {slug && (
    <div class="mt-6">
      <Button
        url={slug}
        variant="text"
        label={linkText || t("common.viewDetails")}
        class="text-accent hover:text-accent-dark text-sm uppercase"
      />
    </div>
  )}
</section>
