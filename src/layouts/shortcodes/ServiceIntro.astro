---
/**
 * ServiceIntro Component
 *
 * Wrapper for the opening narrative/pain-point section of a service page.
 * Uses not-prose and a subtle left border accent for visual distinction.
 *
 * ✅ MDX usage:
 * <ServiceIntro>
 *   Markdown content here...
 * </ServiceIntro>
 */
import { markdownify } from "@/lib/utils/textConverter";

interface Props {
  title?: string;
  class?: string;
}

const { title, class: className = "" } = Astro.props;
---

<section
  class:list={["not-prose mb-10 border-l-4 border-accent pl-6", className]}
>
  {title && (
    <h3
      class="text-h3-sm md:text-h3 font-secondary font-medium text-dark mb-4"
      set:html={markdownify(title)}
    />
  )}
  <div class="prose-styles prose-p:last:mb-0">
    <slot />
  </div>
</section>
