---
import Icons from "@/helpers/Icons.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import Social from "@/components/widgets/Social.astro";
import config from ".astro/config.generated.json";
import socialData from "@/config/social.json";
import { useTranslations } from "@/lib/utils/i18nUtils.ts";
import { markdownify } from "@/lib/utils/textConverter";

const t = await useTranslations(Astro.currentLocale as string);

const {
  settings: { contactInfo },
} = config;

const isCategoryFilteredPage = ["/category/", "/tag/"].some((path) =>
  Astro.url.pathname.includes(`/${config.settings.blogFolder}${path}`),
);

// Social links from config
const socialLinks = socialData.main.filter((link) => link.enable).slice(0, 4);
---

<div class="topbar bg-primary">
  <div class="container">
    <div
      class="grid grid-cols-1 items-center gap-2 py-2.5 md:grid-cols-2 lg:grid-cols-3 lg:gap-4">
      <div
        class="grid grid-cols-1 items-center gap-2 sm:grid-cols-1 md:col-span-1 lg:col-span-2 lg:grid-cols-2 lg:gap-4">
        {/* Left - Working Hours */}
        <div
          class="text-text-light flex items-center justify-center gap-2 lg:justify-start">
          <Icons icon="Clock" class="text-accent h-4 w-4" />
          <span class="font-medium">
            {t("common.workingHours")}:
          </span>
          <span class="">{t("common.workingHoursValue")}</span>
        </div>

        {/* Center - Phone */}
        <div class="flex justify-center">
          <span
            class="bg-accent flex items-center gap-2 rounded-lg px-5 py-0.5 text-base md:text-lg">
            <span class="font-medium">{t("common.call")}</span>
            {
              contactInfo.phone && (
                <p set:html={markdownify(contactInfo.phone)} />
              )
            }
          </span>
        </div>
      </div>

      {/* Right - Language + Social */}
      <div class="flex items-center justify-center gap-5 lg:justify-end">
        {
          config.settings.multilingual.enable && !isCategoryFilteredPage && (
            <LanguageSwitcher appearance="light" />
          )
        }
        <Social
          list={socialLinks}
          linkType="follow"
          layout="classic"
          class="flex items-center gap-2"
        />
      </div>
    </div>
  </div>
</div>
