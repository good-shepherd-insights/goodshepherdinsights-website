---
import { getLocaleUrlCTM } from "@/lib/utils/i18nUtils.ts";
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";
import { markdownify, toSentenceCase } from "@/lib/utils/textConverter";

import config from ".astro/config.generated.json";

type Props = {
  src?: string;
  class?: string;
  width?: string;
  height?: string;
  [key: string]: any;
};

let { src, class: className } = Astro.props;

let {
  logo,
  logoWidth = "320px",
  logoHeight = "80px",
  logoText,
  logoAlternate,
  title,
}: {
  logo: string;
  logoAlternate: string;
  logoWidth: string;
  logoHeight: string;
  logoText: string;
  title: string;
} = config.site;

if (Astro.props.width) {
  logoWidth = Astro.props.width;
}
if (Astro.props.height) {
  logoHeight = Astro.props.height;
}

const mainLogo = src ? src : logo;
---

<a
  href={getLocaleUrlCTM("/", Astro.currentLocale)}
  aria-label={title}
  class:list={["logo-wrapper py-4 lg:py-7", className]}>
  {
    src || logoAlternate || logo ? (
      <>
        <OptimizedImage
          src={mainLogo}
          inlineSvg={mainLogo?.endsWith(".svg")}
          class="logo max-sm:h-12! max-sm:w-52!"
          alt={toSentenceCase("Brand logo of " + title)}
          style={{
            height: logoHeight,
            width: logoWidth,
          }}
        />
        {logoAlternate && (
          <OptimizedImage
            src={logoAlternate}
            inlineSvg={logoAlternate.endsWith(".svg")}
            class="logo-alternate"
            alt={toSentenceCase("Brand logo of " + title)}
            style={{
              height: logoHeight,
              width: logoWidth,
            }}
          />
        )}

        {logoText && (
          <span class="logo-text" set:html={markdownify(logoText)} />
        )}
      </>
    ) : logoText ? (
      logoText
    ) : (
      title
    )
  }
</a>
