---
import type { Section } from "@/types";
import { getEntryCTM } from "@/lib/contentParser.astro";
import overrideObjects from "@/lib/utils/overrideObjects";
import AccordionList from "@/layouts/components/widgets/AccordionList.astro";
import type { faqSectionSchema } from "@/sections.schema";
import type { z } from "astro/zod";
import SectionTitle from "../global/SectionTitle.astro";

type faqSectionType = Section & z.infer<typeof faqSectionSchema>;

// Fetching the default content for the this section
let defaultContent = (
  await getEntryCTM("sections", "faq-section-two", Astro.currentLocale)
)?.data as faqSectionType;

// Enables content customization (e.g., title, description) with a fallback to 'defaultContent' if not provided.
// The 'content' prop should match the structure of 'defaultContent'.
// Allows using this section with different content across multiple pages.
// If 'content' is missing, 'defaultContent' will be used.
let actualContent = overrideObjects(
  { ...defaultContent },
  Astro.props.content,
) as faqSectionType;

let { enable = true, title, list = [] } = actualContent;

if (!enable) {
  return null;
}
const mode = Astro.props.mode ?? "light";
const hasSectionSpacingBottom = Astro.props.hasSectionSpacingBottom ?? false;
---

<section
  class:list={[
    "bg-light",
    hasSectionSpacingBottom && "section-spacing-bottom",
  ]}>
  <div class:list={["container grid grid-cols-1 gap-10 lg:gap-14 xl:gap-20"]}>
    <div class="flex flex-col items-start gap-4 max-lg:order-2 xl:gap-7">
      {
        title && (
          <SectionTitle
            title={title}
            dataAos="reveal-anim-top"
            className="max-w-4xl mx-auto text-center mb-4"
          />
        )
      }
      {list.length > 0 && <AccordionList content={list} mode={mode} />}
    </div>
  </div>
</section>
