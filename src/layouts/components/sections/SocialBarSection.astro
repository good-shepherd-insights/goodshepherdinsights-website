---
import type { Section } from "@/types";
import { z } from "astro/zod";
import { getEntryCTM } from "@/lib/contentParser.astro";
import overrideObjects from "@/lib/utils/overrideObjects.ts";
import type { ctaBarSectionSchema } from "@/sections.schema";
import socialData from "@/config/social.json";
import Button from "../Button.astro";
import { getLocaleUrlCTM } from "@/lib/utils/i18nUtils";
import OptimizedImage from "../utilities/OptimizedImage.astro";
import { markdownify } from "@/lib/utils/textConverter";

const socialLinks = socialData.main.filter(
  (link) => link.enable && link.label !== "Dribbble",
);

// Type
type SectionType = Section & NonNullable<z.infer<typeof ctaBarSectionSchema>>;

// Default content fetch from sections collection
let defaultContent = (
  await getEntryCTM("sections", "social-bar-section", Astro.currentLocale)
)?.data as SectionType;

// Merge with prop overrides
let actualContent = overrideObjects(
  { ...defaultContent },
  Astro.props.content,
) as SectionType;

const {
  enable = true,
  title,
  backgroundImage,
  backgroundImageAlt,
} = actualContent ?? {};

if (!enable) return;
const hasSectionSpacingTop = Astro.props.hasSectionSpacingTop ?? true;
---

<section class:list={["bg-light -mt-30", !hasSectionSpacingTop ? "pt-0" : ""]}>
  {
    backgroundImage && (
      <div class="pointer-events-none">
        <OptimizedImage
          src={backgroundImage}
          alt={backgroundImageAlt}
          width={1920}
          height={617}
          widths={[480, 640, 768, 1024, 1280, 1920]}
          sizes="(min-width: 1536px) 1920px, (min-width: 1280px) 1280px, (min-width: 1024px) 1024px, (min-width: 768px) 768px, 100vw"
          quality={60}
          class="h-full w-full object-cover object-center"
        />
      </div>
    )
  }
  <div class="bg-accent -mb-20 flex h-40 sm:-mb-13 lg:h-44"></div>
  <div class="relative z-1 container">
    <div
      class="bg-body-dark text-text-light right-0 -mb-20 w-full origin-top-left rounded-lg sm:-mb-14">
      <div class="flex flex-col max-md:px-4 lg:flex-row lg:items-stretch">
        {
          title && (
            <h2
              class="text-h6-sm py-3 font-medium text-inherit max-lg:text-center md:px-8 lg:py-10 lg:whitespace-nowrap"
              set:html={markdownify(title)}
            />
          )
        }

        <div
          class="flex w-full flex-wrap divide-y divide-white/10 border-t border-white/10 lg:divide-x lg:divide-y-0 lg:self-stretch lg:border-t-0 lg:border-l">
          {
            socialLinks.map((item) => (
              <Button
                label={item.label}
                variant="text"
                url={getLocaleUrlCTM(item.url, Astro.currentLocale)}
                target="_blank"
                rel="noopener noreferrer"
                class:list={[
                  "flex items-center justify-center px-4 py-2",
                  "text-text-light text-h6-sm hover:text-accent font-medium",
                  "w-1/3 sm:w-auto sm:flex-1",
                  "lg:self-stretch lg:px-6 lg:py-0",
                ]}
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
