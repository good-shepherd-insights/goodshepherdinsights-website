---
import type { Section } from "@/types";
import ContactForm from "../widgets/ContactForm.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import overrideObjects from "@/lib/utils/overrideObjects.ts";
import type { z } from "astro/zod";
import type { contactSectionSchema } from "@/sections.schema";
import SectionBadge from "../global/SectionBadge.astro";
import SectionTitle from "../global/SectionTitle.astro";
import AccordionList from "../widgets/AccordionList.astro";
import OptimizedImage from "../utilities/OptimizedImage.astro";
import { markdownify } from "@/lib/utils/textConverter";

type ContactSection = Section & z.infer<typeof contactSectionSchema>;

let defaultContent = (
  await getEntryCTM("sections", "contact-section", Astro.currentLocale)
)?.data as ContactSection;

let actualContent = overrideObjects(
  { ...defaultContent },
  Astro.props.content,
) as ContactSection;

let {
  enable = true,
  badge,
  title,
  faqList = [],
  decorativeImage,
  decorativeImageAlt,
  form,
  contactBadge,
  contactTitle,
} = actualContent;

if (!enable) return null;
const mode = Astro.props.mode ?? "light";
---

<section class="bg-light overflow-hidden">
  <div class="bg-dark relative mt-8 py-20 lg:py-28">
    <div class="pointer-events-none absolute inset-0 bottom-0 z-0 opacity-80">
      <OptimizedImage
        src={"/images/decorative/pattern/pattern-3.png"}
        alt={"pattern"}
        width={1320}
        height={420}
        class="h-full w-full object-cover object-center"
      />
    </div>
    <div
      class="container grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-14 xl:gap-20">
      <!-- Left -->
      <div class="flex flex-col items-start gap-4 xl:gap-12">
        <div data-aos="reveal-anim-right" data-aos-duration="600">
          {
            badge && (
              <SectionBadge
                title={badge}
                dataAos="reveal-anim-right"
                variant="secondary"
                textColor="accent"
              />
            )
          }
          {
            title && (
              <SectionTitle
                title={title}
                dataAos="reveal-anim-right"
                variant="dark"
              />
            )
          }
        </div>
        {faqList.length > 0 && <AccordionList content={faqList} mode={mode} />}
      </div>
      <!-- Right -->
      <div class="bg-light relative flex flex-col items-start gap-5 lg:-mt-40">
        <div
          class="bg-accent relative flex w-full flex-col gap-2 p-4 text-center lg:gap-4 lg:p-10">
          {
            contactBadge && (
              <div
                class="text-h6-sm font-bold uppercase lg:text-base"
                set:html={markdownify(contactBadge)}
              />
            )
          }
          {
            contactTitle && (
              <h2
                class="text-h2-sm lg:text-h4 xl:text-h2"
                set:html={markdownify(contactTitle)}
              />
            )
          }
          <div
            class="bg-accent absolute top-0 left-1/2 h-6 w-22 -translate-x-1/2 rotate-180 [clip-path:polygon(50%_0%,0%_100%,100%_100%)] lg:h-11 lg:w-42">
          </div>
        </div>
        {
          decorativeImage && (
            <OptimizedImage
              src={decorativeImage}
              alt={decorativeImageAlt}
              width={402}
              height={741}
              widths={[288, 360, 402]}
              sizes="(min-width: 1024px) 402px, 288px"
              class="pointer-events-none absolute -right-54 bottom-0 w-72 lg:-right-75 lg:h-auto lg:w-auto"
            />
          )
        }
        {form && <ContactForm class={"mb-0"} form={form} />}
      </div>
    </div>
  </div>
</section>
