---
import { getCollectionCTM } from "@/lib/contentParser.astro";
import CaseStudyCard from "../cards/CaseStudyCard.astro";
import config from ".astro/config.generated.json";
import type { CollectionEntry } from "astro:content";

type Props = {
  content?: {
    options?: CollectionEntry<"case-studies">["data"]["options"];
  };
};

const content = Astro.props?.content;

let list = await getCollectionCTM(
  config.settings.caseStudiesFolder as "case-studies",
  Astro.currentLocale,
);
list.sort((a, b) => (a.data.weight || 0) - (b.data.weight || 0));
list = content?.options?.limit ? list.slice(0, content?.options?.limit) : list;
---

<section class:list={["bg-light"]}>
  <div class="container">
    <div
      class="grid grid-cols-1 gap-x-4 gap-y-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-x-6 lg:gap-y-10">
      {
        list?.map((item, index) => (
          <CaseStudyCard
            content={item}
            options={content?.options}
            index={index}
          />
        ))
      }
    </div>
  </div>
</section>
