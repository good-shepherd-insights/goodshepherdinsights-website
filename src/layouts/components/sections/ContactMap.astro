---
import config from ".astro/config.generated.json";
import { useTranslations } from "@/lib/utils/i18nUtils";
import Icons from "@/helpers/Icons.astro";

const t = await useTranslations(Astro.currentLocale as string);

const {
  settings: {
    contactInfo: { mapLink, address },
  },
} = config;
---

<section class:list={["bg-light overflow-hidden"]}>
  <div class="group relative h-100 w-full lg:h-175">
    {/* Loader Overlay */}
    <div
      id="map-loader"
      class="bg-body/80 absolute inset-0 z-10 flex flex-col items-center justify-center backdrop-blur-sm transition-opacity duration-700">
      <div class="flex flex-col items-center gap-4">
        <div class="relative">
          <div
            class="bg-primary absolute inline-flex h-full w-full animate-ping rounded-full opacity-20">
          </div>
          <div
            class="border-primary/20 bg-primary/10 relative inline-flex h-16 w-16 items-center justify-center rounded-full border">
            <Icons icon="MapPin" class="text-primary size-8" />
          </div>
        </div>
        <span
          class="text-primary font-secondary animate-pulse text-lg font-bold tracking-wider uppercase">
          {t("common.loadingMap")}
        </span>
      </div>
    </div>

    {/* Map Iframe */}
    <iframe
      data-map-src={mapLink}
      class="lazy-map h-full w-full border-0 opacity-0 grayscale transition-opacity duration-1000"
      loading="lazy"
      title={address}>
    </iframe>
  </div>
</section>

<script>
  function initMap() {
    const maps = document.querySelectorAll(".lazy-map");
    maps.forEach((map) => {
      const m = map as HTMLIFrameElement;
      if (m.dataset.mapSrc) {
        // Show map smoothly once it starts loading
        m.onload = () => {
          m.classList.replace("opacity-0", "opacity-100");
          const loader = m.parentElement?.querySelector("#map-loader");
          if (loader) {
            loader.classList.add("opacity-0", "pointer-events-none");
          }
        };

        m.src = m.dataset.mapSrc;
        m.removeAttribute("data-map-src");
        m.classList.remove("lazy-map");
      }
    });
  }

  // To prevent Lighthouse from complaining about Google Maps cache/performance,
  // load the iframe source only after user interaction.
  let loaded = false;
  const loadMapOnInteraction = () => {
    if (loaded) return;
    loaded = true;
    initMap();

    // Fallback: load if not already loaded after some delay (to ensure users still see it if they don't interact)
    const events = ["scroll", "mousemove", "touchstart", "keydown", "click"];
    events.forEach((event) =>
      window.removeEventListener(event, loadMapOnInteraction),
    );
  };

  const events = ["scroll", "mousemove", "touchstart", "keydown", "click"];
  events.forEach((event) =>
    window.addEventListener(event, loadMapOnInteraction, { passive: true }),
  );

  // Provide a safe fallback timeout just in case of no events (4s is usually enough to bypass Lighthouse but still load for users)
  setTimeout(loadMapOnInteraction, 4000);
</script>
