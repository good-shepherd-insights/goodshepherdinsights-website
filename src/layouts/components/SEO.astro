---
import { Seo } from "astro-seo-meta";
import { Schema } from "astro-seo-schema";
import { getLocaleUrlCTM, supportedLanguages } from "@/lib/utils/i18nUtils.ts";
import { plainify, removeWhitespace } from "@/lib/utils/textConverter";
import config from ".astro/config.generated.json";

export interface SEOProps {
  title?: string;
  metaTitle?: string;
  description?: string;
  metaDescription?: string;
  image?: string;
  canonical?: string;
  keywords?: string[];
  robots?: string;
  author?: string;
  disableTagline?: boolean;
  ogType?: string;
  twitter?: string;
  twitterCard?: string;
  ogLocale?: string;
  schemaData?: any;
}

const {
  title,
  metaTitle,
  description,
  metaDescription,
  image = config.opengraph.image,
  canonical,
  keywords = config.seo.keywords,
  robots = config.seo.robots,
  author = config.seo.author,
  disableTagline,
  ogType = config.opengraph.ogType,
  twitter = config.opengraph.twitter,
  twitterCard = config.opengraph.twitterCard,
  ogLocale = config.opengraph.ogLocale,
  schemaData,
} = Astro.props as SEOProps;

// Normalize title and description
let resolvedTitle = plainify(metaTitle ?? title ?? config.site.title);
let resolvedDescription = plainify(metaDescription ?? description ?? config.site.description);

// Add tagline if not disabled
if (!disableTagline && config.site.tagline) {
  const separator = config.site.taglineSeparator || " - ";
  resolvedTitle += separator + config.site.tagline;
}

resolvedTitle = removeWhitespace(resolvedTitle);
resolvedDescription = removeWhitespace(resolvedDescription);

// Canonical URL
const resolvedCanonical = canonical
  ? canonical
  : getLocaleUrlCTM(new URL(Astro.url.href, Astro.site).href, Astro.currentLocale);

// OG image — make absolute
const ogImage = image.startsWith("http")
  ? image
  : `${config.site.baseUrl}${image}`;

// Alternate language links (i18n routing, not SEO meta)
const alternateTags: Array<{ hreflang: string; href: string }> = [];
if (
  config.settings.multilingual.enable &&
  !resolvedCanonical.includes("blog/category/")
) {
  supportedLanguages.forEach((lang) => {
    alternateTags.push({
      hreflang: lang.languageCode,
      href: getLocaleUrlCTM(Astro.url.href, lang.languageCode),
    });
  });
}
---

<Seo
  title={resolvedTitle}
  description={resolvedDescription}
  keywords={keywords}
  robots={robots}
  icon={config.site.favicon?.image}
  facebook={{
    image: ogImage,
    type: ogType || "website",
    url: resolvedCanonical,
  }}
  twitter={{
    image: ogImage,
    card: twitterCard || "summary_large_image",
    site: twitter || undefined,
  }}
/>
{resolvedCanonical && <link rel="canonical" href={resolvedCanonical} item-prop="url" />}
{alternateTags.map((tag) => (
  <link rel="alternate" hreflang={tag.hreflang} href={tag.href} />
))}
{schemaData && schemaData.map((item: any) => <Schema item={item} />)}
