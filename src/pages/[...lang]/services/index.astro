---
import Base from "@/layouts/Base.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import handleDraftPage from "@/lib/utils/handleDraftPage";
import config from ".astro/config.generated.json";
import { generatePaths } from "@/lib/utils/i18nUtils.ts";
import PageHeader from "@/components/widgets/PageHeader.astro";
import ServicesListSection from "@/components/sections/ServicesListSection.astro";
import FeaturesGridThree from "@/components/sections/FeaturesGridThree.astro";
import StatsMarqueeSection from "@/components/sections/StatsMarqueeSection.astro";
import ProcessSectionTwo from "@/components/sections/ProcessSectionTwo.astro";
import PricingSection from "@/components/sections/PricingSection.astro";
import CTAVideoSectionTwo from "@/components/sections/CTAVideoSectionTwo.astro";
import CTAGallerySection from "@/components/sections/CTAGallerySection.astro";
import BrandLogos from "@/components/sections/BrandLogos.astro";
import CTASection from "@/components/sections/CTASection.astro";

export function getStaticPaths() {
  return generatePaths();
}

const page = await getEntryCTM(
  config.settings.serviceFolder as "services",
  "-index",
  Astro.currentLocale,
);

// Remove drafts pages in production
const response = handleDraftPage(page?.data);
if (response) return response;
---

<Base {...page?.data} hideOffcanvas={true}>
  <PageHeader content={page?.data} />
  <ServicesListSection hasPaddingBottom={true} />
  <FeaturesGridThree />
  <StatsMarqueeSection hasLightBackground={false} />
  <ProcessSectionTwo hasPaddingBottom={true} />
  <PricingSection />
  <CTAVideoSectionTwo hasLightBackground={false} />
  <CTAGallerySection />
  <BrandLogos />
  <CTASection />
</Base>
