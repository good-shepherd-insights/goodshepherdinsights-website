---
import Base from "@/layouts/Base.astro";
import { getCollectionCTM } from "@/lib/contentParser.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import { supportedLanguages } from "@/lib/utils/i18nUtils.ts";
import config from ".astro/config.generated.json";
import ServicesSingle from "@/components/ServicesSingle.astro";
import extractSlug from "@/lib/utils/extractSlug";
import PageHeader from "@/components/widgets/PageHeader.astro";
import FeaturesGridThree from "@/components/sections/FeaturesGridThree.astro";
import StatsMarqueeSection from "@/components/sections/StatsMarqueeSection.astro";
import FaqSectionTwo from "@/components/sections/FaqSectionTwo.astro";
import CTAGallerySection from "@/components/sections/CTAGallerySection.astro";
import CTASection from "@/components/sections/CTASection.astro";
import { Schema } from "astro-seo-schema";
import type { Service, FAQPage } from "schema-dts";
import { absoluteUrl } from "@/lib/utils/absoluteUrl";
import trailingSlashChecker from "@/lib/utils/trailingSlashChecker";

export async function getStaticPaths() {
  const paths = await Promise.all(
    supportedLanguages.map(async (lang) => {
      const serviceFolder = config.settings.serviceFolder as "services";
      const { defaultLanguage, showDefaultLangInUrl } =
        config.settings.multilingual;

      const serviceIndex = await getEntryCTM(
        serviceFolder as "services",
        "-index",
        lang.languageCode,
      );

      let services = await getCollectionCTM(
        serviceFolder as "services",
        lang.languageCode,
      );

      // If draft true in index.md file frontmatter don't include any page related to this page collection in production
      if (serviceIndex?.data.draft && import.meta.env.PROD) {
        return [];
      }

      return services.map((service) => ({
        params: {
          lang:
            lang.languageCode === defaultLanguage && !showDefaultLangInUrl
              ? undefined
              : lang.languageCode,
          single: extractSlug(service).split("/").pop(),
        },
        props: {
          service,
          serviceIndex,
        },
      }));
    }),
  );

  return paths.flat();
}

const { service, serviceIndex } = Astro.props;

const baseUrl = trailingSlashChecker(Astro.url.origin);
const baseUrlClean = baseUrl.replace(/\/$/, "");
const orgData = config.seo.organization || {};

// Resolve canonical for this service page
const resolvedCanonical = Astro.props.canonical
  ? absoluteUrl(Astro.props.canonical, Astro)
  : absoluteUrl(Astro.url.pathname, Astro);

// Build Service schema inline
const serviceSchema: Service = {
  "@type": "Service",
  "@id": `${resolvedCanonical}#service`,
  name: service?.data?.title,
  description: service?.data?.description || service?.data?.metaDescription,
  url: resolvedCanonical,
  ...(service?.data?.image && { image: absoluteUrl(service.data.image, Astro) }),
  provider: { "@id": `${baseUrlClean}/#organization` },
  serviceType: service?.data?.serviceType || "Consulting Service",
  areaServed: {
    "@type": "State",
    name: orgData.addressRegion || "USA",
  },
};

// Build FAQPage schema from FaqSectionTwo data
// Fetch the FAQ section data for this service page
const faqSectionData = (
  await getEntryCTM("sections", "faq-section-two", Astro.currentLocale)
)?.data;

const faqList = faqSectionData?.list
  ?.filter((item: any) => item.enable !== false)
  ?.map((item: any) => ({
    "@type": "Question",
    name: item.title,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.content,
    },
  })) || [];

let faqSchema: FAQPage | undefined;
if (faqList.length > 0) {
  faqSchema = {
    "@type": "FAQPage",
    "@id": `${resolvedCanonical}#faqpage`,
    mainEntity: faqList,
  };
}
---

<Base {...service?.data} hideOffcanvas={true}>
  <PageHeader
    content={{
      badge: service?.data?.title,
      title: service?.data?.title,
      image: service?.data?.image,
      imageText: service?.data?.title,
    }}
    contentClass="max-w-2xl!"
  />
  <ServicesSingle content={service} hasPaddingBottom={true} />
  <FeaturesGridThree />
  <StatsMarqueeSection hasLightBackground={false} />
  <FaqSectionTwo mode="shadow" />
  <CTAGallerySection />
  <CTASection />

  <!-- Page-specific structured data -->
  <Schema item={{ "@context": "https://schema.org", ...serviceSchema } as any} />
  {faqSchema && <Schema item={{ "@context": "https://schema.org", ...faqSchema } as any} />}
</Base>
