---
import Base from "@/layouts/Base.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import { generatePaths } from "@/lib/utils/i18nUtils.ts";
import FaqSection from "@/components/sections/FaqSection.astro";
import CTASection from "@/components/sections/CTASection.astro";
import HeroSection from "@/components/sections/HeroSection.astro";
import FeaturesGrid from "@/components/sections/FeaturesGrid.astro";
import StatsSection from "@/components/sections/StatsSection.astro";
import AboutSection from "@/components/sections/AboutSection.astro";
import ServicesSection from "@/components/sections/ServicesSection.astro";
import CTAVideoSection from "@/components/sections/CTAVideoSection.astro";
// Removed from homepage layout — available for future use:
import TestimonialSection from "@/components/sections/TestimonialSection.astro";
import CaseStudiesSection from "@/components/sections/CaseStudiesSection.astro";
import TeamSection from "@/components/sections/TeamSection.astro";
import BlogSection from "@/components/sections/BlogSection.astro";
import { Schema } from "astro-seo-schema";
import type { LocalBusiness } from "schema-dts";
import { absoluteUrl } from "@/lib/utils/absoluteUrl";
import trailingSlashChecker from "@/lib/utils/trailingSlashChecker";
import config from ".astro/config.generated.json";

export function getStaticPaths() {
  return generatePaths();
}

const page = await getEntryCTM("homepage", "-index", Astro.currentLocale);

const baseUrl = trailingSlashChecker(Astro.url.origin);
const baseUrlClean = baseUrl.replace(/\/$/, "");
const orgData = config.seo.organization || {};

// Build LocalBusiness schema inline
const localBusinessSchema: LocalBusiness = {
  "@type": "LocalBusiness",
  "@id": `${baseUrlClean}/#localbusiness`,
  name: config.seo.author,
  description: page?.data?.metaDescription || config.site.description,
  url: baseUrl,
  ...(page?.data?.image && { image: absoluteUrl(page.data.image, Astro) }),
  ...(orgData.telephone && { telephone: orgData.telephone }),
  ...(orgData.email && { email: orgData.email }),
  ...((orgData.streetAddress || orgData.addressLocality || orgData.addressRegion) && {
    address: {
      "@type": "PostalAddress",
      ...(orgData.streetAddress && { streetAddress: orgData.streetAddress }),
      ...(orgData.addressLocality && { addressLocality: orgData.addressLocality }),
      ...(orgData.addressRegion && { addressRegion: orgData.addressRegion }),
    },
  }),
  sameAs: config.social?.main
    ?.filter((item: any) => item.enable)
    .map((item: any) => item.url) || [],
};
---

<Base {...page?.data} headerLayout="header-1">
  <HeroSection />
  {/* SHELVED: FeaturesGrid */}
  <ServicesSection />
  {/* SHELVED: StatsSection */}
  <AboutSection />
  {/* SHELVED: CTAVideoSection */}
  {/* SHELVED: TestimonialSection */}
  {/* SHELVED: CaseStudiesSection */}
  {/* SHELVED: FaqSection */}
  {/* SHELVED: TeamSection */}
  <BlogSection />
  <CTASection />

  <!-- Page-specific structured data -->
  <Schema item={{ "@context": "https://schema.org", ...localBusinessSchema } as any} />
</Base>
