---
// PRUNED: Renamed from team/index.astro on 2026-06-04. Reactivate: remove the underscore prefix to restore this route. Reason: Only in footer primary, not in header navbar; team data stays for TeamSection on About page.

import Base from "@/layouts/Base.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import handleDraftPage from "@/lib/utils/handleDraftPage";
import { generatePaths } from "@/lib/utils/i18nUtils.ts";
import PageHeader from "@/components/widgets/PageHeader.astro";
import AboutSectionTwo from "@/components/sections/AboutSectionTwo.astro";
import TeamSection from "@/components/sections/TeamSection.astro";
import AboutMetricsSection from "@/components/sections/AboutMetricsSection.astro";
import StatsMarqueeSection from "@/components/sections/StatsMarqueeSection.astro";
import CTAGallerySection from "@/components/sections/CTAGallerySection.astro";
import CTASection from "@/components/sections/CTASection.astro";

export function getStaticPaths() {
  return generatePaths();
}

const page = await getEntryCTM("team", "-index", Astro.currentLocale);

// Remove drafts pages in production
const response = handleDraftPage(page?.data);
if (response) return response;
---

<Base {...page?.data}>
  <PageHeader content={page?.data} contentClass="max-w-7xl! xl:px-10" />
  <AboutSectionTwo hasSectionSpacingBottom={true} />
  <TeamSection
    content={page?.data?.teamSection}
    badgeVariant="secondary"
    hasSectionSpacingBottom={true}
  />
  <AboutMetricsSection hasLightBackground={true} />
  <StatsMarqueeSection hasLightBackground={true} />
  <CTAGallerySection />
  <CTASection />
</Base>
